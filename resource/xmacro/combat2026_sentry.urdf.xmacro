<?xml version="1.0"?>
<robot name="rm26_example_robot">

    <!-- Base footprint -->
    <link name="base_footprint"/>
    
    <!-- Chassis link -->
    <link name="chassis">
        <inertial>
            <origin xyz="0 0 0.055" rpy="0 0 0"/>
            <mass value="15.0"/>
            <inertia ixx="0.0312" ixy="0" ixz="0" iyy="0.0702" iyz="0" izz="0.0864"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="model://rmua19_standard_robot/meshes/chassis_base.dae"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0.045" rpy="0 0 0"/>
            <geometry>
                <box size="0.36 0.24 0.13"/>
            </geometry>
        </collision>
    </link>
    
    <!-- Base footprint to chassis joint -->
    <joint name="base_to_chassis" type="fixed">
        <parent link="base_footprint"/>
        <child link="chassis"/>
        <origin xyz="0 0 0.09" rpy="0 0 0"/>
    </joint>

    <!-- Base yaw odom link-->
    <link name="base_yaw_odom">
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
        </inertial>
    </link>
    
    <!-- Chassis to base yaw odom joint -->
    <joint name="base_yaw_odom_joint" type="fixed">
        <parent link="chassis"/>
        <child link="base_yaw_odom"/>
        <origin xyz="0 0 0.087" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.14159" upper="3.14159" effort="100" velocity="50"/>
    </joint>

    <!-- Base yaw link-->
    <link name="base_yaw">
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
        </inertial>
    </link>
    
    <!-- base yaw odom to base yaw joint -->
    <joint name="base_yaw_joint" type="revolute">
        <parent link="base_yaw_odom"/>
        <child link="base_yaw"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.14159" upper="3.14159" effort="100" velocity="50"/>
    </joint>

    <!-- front mid360 link-->
    <link name="front_mid360">
        <inertial>
            <origin xyz="0 0 0.02" rpy="0 0 0"/>
            <mass value="0.005"/>
            <inertia ixx="0.0000008" ixy="0" ixz="0" iyy="0.0000008" iyz="0" izz="0.0000004"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="3.14159 0 0"/>
            <geometry>
                <mesh filename="model://mid360/meshes/mid360.dae"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0.02" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.04" length="0.04"/>
            </geometry>
        </collision>
    </link>

    <!-- Base yaw to front mid360 joint -->
    <joint name="livox_joint" type="fixed">
        <parent link="base_yaw"/>
        <child link="front_mid360"/>
        <origin xyz="0.12088 0 0.17608" rpy="-${pi/6} 0 -${pi/2}"/>
    </joint>

    <!-- vision -->
    <link name="odom_vision" />
    <link name="gimbal_link" />
    
    <joint name="vision_joint" type="floating">
        <parent link="base_yaw_odom"/>
        <child link="odom_vision"/>
    </joint>

    
    <joint name="gimbal_joint" type="floating">
        <parent link="odom_vision" />
        <child link="gimbal_link" />
    </joint>

    <link name="camera_link" />

    <joint name="camera_joint" type="fixed">
        <origin xyz="-0.045 0.0  0.07679" rpy="0.0 0.0 0.0" />
        <parent link="gimbal_link" />
        <child link="camera_link" />
    </joint>

    <link name="camera_optical_frame" />

    <joint name="camera_optical_joint" type="fixed">
        <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}" />
        <parent link="camera_link" />
        <child link="camera_optical_frame" />
    </joint>

</robot>